# SUCCESS Bank — backend environment template
# Copy to backend/.env and fill in real values for local dev.
# NEVER commit a real .env.

# --- App ---
APP_ENV=development            # development | staging | production
APP_NAME=SUCCESS Bank API
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Security ---
JWT_SECRET=change-me-please-use-a-32+-char-random-string
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
PASSWORD_PEPPER=optional-extra-secret-mixed-into-hashes

# --- Database ---
DATABASE_URL=postgresql+asyncpg://success:success_dev_pw@localhost:5432/success_bank

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (S3-compatible / MinIO) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=successadmin
S3_SECRET_KEY=successadmin_dev_pw
S3_BUCKET=success-attachments
S3_REGION=us-east-1

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173

# --- Email (SMTP — dev uses MailHog/console) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@successbank.local

# --- SLA defaults (minutes) — overridden by sla_policies table once seeded ---
SLA_CRITICAL_MINUTES=120
SLA_HIGH_MINUTES=360
SLA_MEDIUM_MINUTES=1440
SLA_LOW_MINUTES=4320
